DirectorySlash Off
Options -Indexes

RewriteEngine On

RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/$ /$1 [R=301,L]

RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)$  /$1/index.html [L]

RedirectPermanent /install/rails /install/server-bindings
RedirectPermanent /install/ruby /install/server-bindings
RedirectPermanent /install/php /install/server-bindings
RedirectPermanent /install/elixir /install/server-bindings
RedirectPermanent /install/rust /install/server-bindings
RedirectPermanent /install/npm /install#npm
RedirectPermanent /install/zip /install
RedirectPermanent /install/cdn /install
RedirectPermanent /install/download /install

RedirectPermanent /install/protocol /install/server-bindings
RedirectPermanent /install/server-protocol /install/server-bindings

RedirectPermanent /community /support
RedirectPermanent /discuss https://github.com/unpoly/unpoly/discussions
RedirectPermanent /discussion https://github.com/unpoly/unpoly/discussions
RedirectPermanent /discussions https://github.com/unpoly/unpoly/discussions
RedirectPermanent /talk https://github.com/unpoly/unpoly/discussions
RedirectPermanent /forum https://github.com/unpoly/unpoly/discussions

<%= guide.migrate_redirects %>

Header set Cache-Control "max-age=0, private"

<FilesMatch "\.(css|jpg|jpeg|png|svg|gif|js|ico)$">
  Header set Cache-Control "max-age=2628000, public"
</FilesMatch>

# Exclude crawlers from hostnames like:
# - v1.unpoly.com
# - v2.unpoly.com
# - pre.unpoly.com
RewriteCond %{HTTP_HOST} ^(v\d+|pre)\.unpoly\.com$
RewriteRule ^robots\.txt$ /robots.exclude.txt [L]

# v3 is the current version, so let's redirect
# v3.unpoly.com/foo to unpoly.com/foo
RewriteCond %{HTTP_HOST} ^(v3|www)\.unpoly\.com$
RewriteRule ^(.*)$ https://unpoly.com/$1 [R=307,L]
